# ---------------------------------------------------------------------------
# Shopify Admin API credentials
# ---------------------------------------------------------------------------
# Copy this file to `.env` and paste in the values you received over a
# SECURE CHANNEL (1Password / Bitwarden / encrypted message — never plain
# email or chat).
#
#   cp .env.example .env
#
# NOTE — The custom Shopify app is already installed on the store with the
# required scopes:  read_products, write_products, read_inventory,
# write_inventory.  You do NOT need to create or install anything in the
# Shopify admin.
#
# Field reference:
#
#  SHOPIFY_STORE
#    The store handle — the part BEFORE `.myshopify.com`.
#    Example: if the admin URL is https://geggamoja.myshopify.com/admin
#             then SHOPIFY_STORE=geggamoja
#
#  SHOPIFY_ADMIN_TOKEN
#    Admin API access token. Starts with `shpat_`. Treat it like a password
#    — never commit it to git or paste it into Slack/Jira/screenshots.
#    If it leaks, request a fresh token immediately; the old one will be
#    revoked.
#
#  SHOPIFY_API_VERSION
#    Shopify Admin API version. Use the latest stable release.
#    See: https://shopify.dev/docs/api/usage/versioning#release-schedule
# ---------------------------------------------------------------------------

SHOPIFY_STORE=your-store
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2025-01
