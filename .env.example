# ---------------------------------------------------------------------------
# Shopify Admin API credentials — B2C and B2B stores
# ---------------------------------------------------------------------------
# Copy this file to `.env` and paste in the values you received over a
# SECURE CHANNEL (1Password / Bitwarden / encrypted message — never plain
# email or chat).
#
#   cp .env.example .env
#
# The custom Shopify app is already installed on BOTH stores with scopes:
#   read_products, write_products, read_inventory, write_inventory
#
# Each store has its own handle and token — always pair the correct token
# with the correct store URL when calling the API.
# ---------------------------------------------------------------------------

# B2C store (consumer storefront)
SHOPIFY_STORE=geggamoja
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# B2B store (wholesale)
SHOPIFY_STORE_B2B=geggamojab2b
SHOPIFY_ADMIN_TOKEN_B2B=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Shopify Admin API version
SHOPIFY_API_VERSION=2025-01
